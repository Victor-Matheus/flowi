<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flowi — Demo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-50: #E1F5EE;
    --green-100: #9FE1CB;
    --green-400: #1D9E75;
    --green-600: #0F6E56;
    --green-800: #085041;
    --gray-50: #F7F6F2;
    --gray-100: #EEEDE8;
    --gray-200: #D3D1C7;
    --gray-400: #888780;
    --gray-500: #5F5E5A;
    --gray-800: #2C2C2A;
    --red-50: #FCEBEB;
    --red-100: #F7C1C1;
    --red-600: #A32D2D;
    --amber-50: #FAEEDA;
    --amber-600: #854F0B;
    --blue-50: #E6F1FB;
    --blue-600: #185FA5;
  }

  html, body { height: 100%; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--gray-50);
    color: var(--gray-800);
    font-size: 13px;
    display: flex;
    flex-direction: column;
  }

  /* TOP BAR */
  .topnav {
    height: 48px; background: white;
    border-bottom: 1px solid var(--gray-100);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 1.5rem; flex-shrink: 0;
  }
  .topnav-logo {
    font-family: 'Syne', sans-serif; font-size: 16px;
    font-weight: 800; letter-spacing: -0.5px; color: var(--green-600);
    display: flex; align-items: center; gap: 6px;
  }
  .logo-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green-400); }
  .topnav-right { display: flex; align-items: center; gap: 12px; }
  .demo-badge {
    background: var(--amber-50); color: var(--amber-600);
    font-size: 10px; font-weight: 500; padding: 3px 10px;
    border-radius: 20px; letter-spacing: 0.5px;
  }
  .back-link {
    font-size: 12px; color: var(--gray-400);
    text-decoration: none; display: flex; align-items: center; gap: 4px;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--gray-800); }

  /* LAYOUT */
  .app { display: flex; flex: 1; overflow: hidden; }

  /* SIDEBAR */
  .sidebar {
    width: 200px; background: white;
    border-right: 1px solid var(--gray-100);
    display: flex; flex-direction: column;
    padding: 12px 0; flex-shrink: 0;
    overflow-y: auto;
  }
  .nav-section { padding: 0 12px; margin-bottom: 4px; }
  .nav-label {
    font-size: 10px; font-weight: 500; color: var(--gray-400);
    letter-spacing: 0.8px; text-transform: uppercase;
    padding: 8px 8px 4px;
  }
  .nav-item {
    display: flex; align-items: center; gap: 9px;
    padding: 8px; border-radius: 7px;
    font-size: 12px; color: var(--gray-500); cursor: pointer;
    transition: all 0.15s; margin-bottom: 1px;
    user-select: none;
  }
  .nav-item:hover { background: var(--gray-50); color: var(--gray-800); }
  .nav-item.active { background: var(--green-50); color: var(--green-600); font-weight: 500; }
  .nav-item .icon { font-size: 16px; flex-shrink: 0; }
  .sidebar-spacer { flex: 1; }
  .sidebar-user {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 16px; border-top: 1px solid var(--gray-100);
    margin-top: 8px;
  }
  .user-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--green-50); color: var(--green-600);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 500; flex-shrink: 0;
  }
  .user-info .name { font-size: 11px; font-weight: 500; }
  .user-info .plan { font-size: 10px; color: var(--gray-400); }

  /* MAIN */
  .main { flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 20px; }

  /* PAGE HEADER */
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; }
  .page-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 3px; }
  .page-sub { font-size: 11px; color: var(--gray-400); }
  .header-actions { display: flex; gap: 8px; }
  .btn-sm {
    padding: 7px 14px; border-radius: 7px; font-size: 12px;
    font-family: 'DM Sans', sans-serif; cursor: pointer;
    transition: all 0.15s; font-weight: 400; border: none;
  }
  .btn-outline { background: white; border: 1px solid var(--gray-200); color: var(--gray-500); }
  .btn-outline:hover { border-color: var(--gray-400); color: var(--gray-800); }
  .btn-filled { background: var(--green-600); color: var(--green-50); font-weight: 500; }
  .btn-filled:hover { background: var(--green-800); }

  /* METRICS */
  .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .metric {
    background: white; border: 1px solid var(--gray-100);
    border-radius: 10px; padding: 14px 16px;
    transition: border-color 0.2s;
  }
  .metric:hover { border-color: var(--gray-200); }
  .metric-label { font-size: 11px; color: var(--gray-400); margin-bottom: 8px; }
  .metric-value { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -0.8px; margin-bottom: 5px; }
  .metric-value.green { color: var(--green-600); }
  .metric-value.red { color: var(--red-600); }
  .metric-value.amber { color: var(--amber-600); }
  .metric-delta { font-size: 10px; color: var(--gray-400); display: flex; align-items: center; gap: 3px; }
  .metric-delta.up { color: var(--green-600); }
  .metric-delta.down { color: var(--red-600); }

  /* CARD */
  .card { background: white; border: 1px solid var(--gray-100); border-radius: 10px; overflow: hidden; }
  .card-header {
    padding: 14px 16px; border-bottom: 1px solid var(--gray-100);
    display: flex; align-items: center; justify-content: space-between;
  }
  .card-title { font-size: 13px; font-weight: 500; }
  .card-sub { font-size: 11px; color: var(--gray-400); margin-top: 2px; }
  .card-body { padding: 16px; }

  /* TWO COLS */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .three-col { display: grid; grid-template-columns: 2fr 1fr; gap: 12px; }

  /* CHART BARS */
  .bar-chart { display: flex; flex-direction: column; gap: 8px; }
  .bar-row { display: flex; align-items: center; gap: 10px; }
  .bar-month { width: 56px; font-size: 11px; color: var(--gray-400); text-align: right; flex-shrink: 0; }
  .bar-track { flex: 1; height: 22px; background: var(--gray-50); border-radius: 5px; overflow: hidden; }
  .bar-fill {
    height: 100%; border-radius: 5px;
    display: flex; align-items: center; padding-left: 10px;
    font-size: 10px; font-weight: 500; color: var(--green-800);
    background: var(--green-50);
    transition: width 1s cubic-bezier(.4,0,.2,1);
  }
  .bar-fill.animate { width: 0 !important; }

  /* TABLE */
  .cobr-table { width: 100%; border-collapse: collapse; }
  .cobr-table thead th {
    padding: 8px 16px; text-align: left;
    font-size: 10px; font-weight: 500; color: var(--gray-400);
    text-transform: uppercase; letter-spacing: 0.5px;
    background: var(--gray-50); border-bottom: 1px solid var(--gray-100);
  }
  .cobr-table tbody tr {
    border-bottom: 1px solid var(--gray-100);
    cursor: pointer; transition: background 0.1s;
  }
  .cobr-table tbody tr:hover { background: var(--gray-50); }
  .cobr-table tbody tr:last-child { border-bottom: none; }
  .cobr-table td { padding: 11px 16px; }
  .client-name { font-size: 12px; font-weight: 500; margin-bottom: 2px; }
  .client-type { font-size: 10px; color: var(--gray-400); }
  .cobr-val { font-size: 12px; font-weight: 500; }
  .cobr-date { font-size: 11px; color: var(--gray-400); }

  /* BADGES */
  .badge {
    display: inline-flex; align-items: center;
    padding: 3px 9px; border-radius: 20px;
    font-size: 10px; font-weight: 500;
  }
  .badge.pago { background: var(--green-50); color: var(--green-800); }
  .badge.pendente { background: var(--amber-50); color: var(--amber-600); }
  .badge.atrasado { background: var(--red-50); color: var(--red-600); }
  .badge.agendado { background: var(--blue-50); color: var(--blue-600); }

  /* RÉGUA */
  .regua-list { display: flex; flex-direction: column; }
  .regua-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 0; border-bottom: 1px solid var(--gray-100);
  }
  .regua-item:last-child { border-bottom: none; }
  .regua-icon {
    width: 32px; height: 32px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; flex-shrink: 0;
  }
  .regua-icon.wpp { background: var(--green-50); color: var(--green-600); }
  .regua-icon.mail { background: var(--blue-50); color: var(--blue-600); }
  .regua-icon.sms { background: var(--amber-50); color: var(--amber-600); }
  .regua-body { flex: 1; min-width: 0; }
  .regua-title { font-size: 12px; font-weight: 500; }
  .regua-desc { font-size: 10px; color: var(--gray-400); margin-top: 2px; }
  .toggle {
    width: 32px; height: 18px; border-radius: 20px;
    background: var(--green-400); position: relative;
    cursor: pointer; flex-shrink: 0; transition: background 0.2s;
  }
  .toggle::after {
    content: ''; position: absolute;
    width: 14px; height: 14px; border-radius: 50%;
    background: white; top: 2px; right: 2px;
    transition: right 0.2s, left 0.2s;
  }
  .toggle.off { background: var(--gray-200); }
  .toggle.off::after { right: auto; left: 2px; }

  /* SCORE */
  .score-list { display: flex; flex-direction: column; gap: 10px; }
  .score-row { display: flex; align-items: center; gap: 10px; }
  .score-name { flex: 1; font-size: 12px; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .score-track { width: 90px; height: 6px; background: var(--gray-100); border-radius: 3px; overflow: hidden; flex-shrink: 0; }
  .score-bar { height: 100%; border-radius: 3px; }
  .score-bar.low { background: var(--green-400); }
  .score-bar.med { background: #EF9F27; }
  .score-bar.high { background: #E24B4A; }
  .score-val { width: 26px; font-size: 11px; font-weight: 500; text-align: right; flex-shrink: 0; }
  .score-val.low { color: var(--green-600); }
  .score-val.med { color: var(--amber-600); }
  .score-val.high { color: var(--red-600); }

  /* CONCILIAÇÃO */
  .concil-list { display: flex; flex-direction: column; gap: 0; }
  .concil-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid var(--gray-100);
  }
  .concil-item:last-child { border-bottom: none; }
  .concil-icon {
    width: 28px; height: 28px; border-radius: 6px;
    background: var(--green-50); color: var(--green-600);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
  }
  .concil-icon.mismatch { background: var(--red-50); color: var(--red-600); }
  .concil-body { flex: 1; }
  .concil-title { font-size: 11px; font-weight: 500; }
  .concil-desc { font-size: 10px; color: var(--gray-400); margin-top: 1px; }
  .concil-val { font-size: 11px; font-weight: 500; flex-shrink: 0; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .main > * { animation: fadeIn 0.4s ease both; }
  .main > *:nth-child(1) { animation-delay: 0.05s; }
  .main > *:nth-child(2) { animation-delay: 0.1s; }
  .main > *:nth-child(3) { animation-delay: 0.15s; }
  .main > *:nth-child(4) { animation-delay: 0.2s; }
  .main > *:nth-child(5) { animation-delay: 0.25s; }
</style>
</head>
<body>

<div class="topnav">
  <div class="topnav-logo">
    <div class="logo-dot"></div>
    flowi
  </div>
  <div class="topnav-right">
    <span class="demo-badge">DEMO</span>
    <a href="index.html" class="back-link">← Voltar ao site</a>
  </div>
</div>

<div class="app">

  <aside class="sidebar">
    <div class="nav-section">
      <div class="nav-label">Principal</div>
      <div class="nav-item active" onclick="setActive(this)">
        <span class="icon">📊</span> Dashboard
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">💳</span> Cobranças
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">👥</span> Clientes
      </div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Automação</div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">🤖</span> Régua
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">🔔</span> Notificações
      </div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Financeiro</div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">🔄</span> Conciliação
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">📈</span> Relatórios
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">⚡</span> Antecipação
      </div>
    </div>
    <div class="sidebar-spacer"></div>
    <div class="nav-section">
      <div class="nav-item" onclick="setActive(this)">
        <span class="icon">⚙️</span> Configurações
      </div>
    </div>
    <div class="sidebar-user">
      <div class="user-avatar">VC</div>
      <div class="user-info">
        <div class="name">Você</div>
        <div class="plan">Plano Pro</div>
      </div>
    </div>
  </aside>

  <main class="main">

    <div class="page-header">
      <div>
        <div class="page-title">Visão geral — maio 2026</div>
        <div class="page-sub">Última atualização: agora mesmo · 23 cobranças ativas</div>
      </div>
      <div class="header-actions">
        <button class="btn-sm btn-outline">Exportar</button>
        <button class="btn-sm btn-filled">+ Nova cobrança</button>
      </div>
    </div>

    <div class="metrics">
      <div class="metric">
        <div class="metric-label">Recebido no mês</div>
        <div class="metric-value green">R$84.300</div>
        <div class="metric-delta up">↑ 12% vs abril</div>
      </div>
      <div class="metric">
        <div class="metric-label">A receber</div>
        <div class="metric-value">R$31.500</div>
        <div class="metric-delta">18 cobranças abertas</div>
      </div>
      <div class="metric">
        <div class="metric-label">Em atraso</div>
        <div class="metric-value red">R$7.200</div>
        <div class="metric-delta down">4 clientes · régua ativa</div>
      </div>
      <div class="metric">
        <div class="metric-label">Taxa de recebimento</div>
        <div class="metric-value amber">89%</div>
        <div class="metric-delta">Meta: 95%</div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Recebimentos por mês</div>
          <div class="card-sub">Janeiro – maio 2026</div>
        </div>
      </div>
      <div class="card-body">
        <div class="bar-chart" id="barChart">
          <div class="bar-row">
            <div class="bar-month">Jan</div>
            <div class="bar-track"><div class="bar-fill animate" data-width="58%">R$58k</div></div>
          </div>
          <div class="bar-row">
            <div class="bar-month">Fev</div>
            <div class="bar-track"><div class="bar-fill animate" data-width="63%">R$63k</div></div>
          </div>
          <div class="bar-row">
            <div class="bar-month">Mar</div>
            <div class="bar-track"><div class="bar-fill animate" data-width="71%">R$71k</div></div>
          </div>
          <div class="bar-row">
            <div class="bar-month">Abr</div>
            <div class="bar-track"><div class="bar-fill animate" data-width="75%">R$75k</div></div>
          </div>
          <div class="bar-row">
            <div class="bar-month">Mai</div>
            <div class="bar-track"><div class="bar-fill animate" data-width="84%">R$84k</div></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Cobranças recentes</div>
          <div class="card-sub">Últimas 5 transações</div>
        </div>
        <button class="btn-sm btn-outline">Ver todas</button>
      </div>
      <table class="cobr-table">
        <thead>
          <tr>
            <th>Cliente</th>
            <th>Valor</th>
            <th>Vencimento</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><div class="client-name">Agência Hive</div><div class="client-type">Gestão de tráfego pago</div></td>
            <td><div class="cobr-val">R$12.000</div></td>
            <td><div class="cobr-date">05/05/2026</div></td>
            <td><span class="badge pago">Pago</span></td>
          </tr>
          <tr>
            <td><div class="client-name">Nova Mídia Co.</div><div class="client-type">Produção de conteúdo</div></td>
            <td><div class="cobr-val">R$8.500</div></td>
            <td><div class="cobr-date">10/05/2026</div></td>
            <td><span class="badge pendente">Pendente</span></td>
          </tr>
          <tr>
            <td><div class="client-name">GrowthLab</div><div class="client-type">Consultoria de growth</div></td>
            <td><div class="cobr-val">R$5.200</div></td>
            <td><div class="cobr-date">01/05/2026</div></td>
            <td><span class="badge atrasado">Atrasado</span></td>
          </tr>
          <tr>
            <td><div class="client-name">Pixel & Co.</div><div class="client-type">Design e branding</div></td>
            <td><div class="cobr-val">R$3.800</div></td>
            <td><div class="cobr-date">15/05/2026</div></td>
            <td><span class="badge agendado">Agendado</span></td>
          </tr>
          <tr>
            <td><div class="client-name">Tráfego Forte</div><div class="client-type">Mídia performance</div></td>
            <td><div class="cobr-val">R$9.100</div></td>
            <td><div class="cobr-date">08/05/2026</div></td>
            <td><span class="badge pago">Pago</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="two-col">

      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Régua de cobrança</div>
            <div class="card-sub">4 etapas ativas</div>
          </div>
          <button class="btn-sm btn-outline">Editar</button>
        </div>
        <div class="card-body">
          <div class="regua-list">
            <div class="regua-item">
              <div class="regua-icon wpp">💬</div>
              <div class="regua-body">
                <div class="regua-title">WhatsApp — D-3</div>
                <div class="regua-desc">Lembrete amigável 3 dias antes</div>
              </div>
              <div class="toggle" onclick="toggleSwitch(this)"></div>
            </div>
            <div class="regua-item">
              <div class="regua-icon mail">✉️</div>
              <div class="regua-body">
                <div class="regua-title">E-mail — vencimento</div>
                <div class="regua-desc">Link de pagamento no dia</div>
              </div>
              <div class="toggle" onclick="toggleSwitch(this)"></div>
            </div>
            <div class="regua-item">
              <div class="regua-icon wpp">💬</div>
              <div class="regua-body">
                <div class="regua-title">WhatsApp — D+2</div>
                <div class="regua-desc">Retry automático em atraso</div>
              </div>
              <div class="toggle" onclick="toggleSwitch(this)"></div>
            </div>
            <div class="regua-item">
              <div class="regua-icon sms">📱</div>
              <div class="regua-body">
                <div class="regua-title">SMS — D+7</div>
                <div class="regua-desc">Última notificação automática</div>
              </div>
              <div class="toggle" onclick="toggleSwitch(this)"></div>
            </div>
          </div>
        </div>
      </div>

      <div style="display: flex; flex-direction: column; gap: 12px;">

        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Score de inadimplência</div>
              <div class="card-sub">Baseado em histórico</div>
            </div>
          </div>
          <div class="card-body">
            <div class="score-list">
              <div class="score-row">
                <div class="score-name">Agência Hive</div>
                <div class="score-track"><div class="score-bar low" style="width:12%"></div></div>
                <div class="score-val low">12</div>
              </div>
              <div class="score-row">
                <div class="score-name">Nova Mídia Co.</div>
                <div class="score-track"><div class="score-bar med" style="width:38%"></div></div>
                <div class="score-val med">38</div>
              </div>
              <div class="score-row">
                <div class="score-name">GrowthLab</div>
                <div class="score-track"><div class="score-bar high" style="width:74%"></div></div>
                <div class="score-val high">74</div>
              </div>
              <div class="score-row">
                <div class="score-name">Pixel & Co.</div>
                <div class="score-track"><div class="score-bar low" style="width:8%"></div></div>
                <div class="score-val low">8</div>
              </div>
              <div class="score-row">
                <div class="score-name">Tráfego Forte</div>
                <div class="score-track"><div class="score-bar low" style="width:21%"></div></div>
                <div class="score-val low">21</div>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="card-title">Conciliação automática</div>
          </div>
          <div class="card-body" style="padding: 12px 16px;">
            <div class="concil-list">
              <div class="concil-item">
                <div class="concil-icon">✓</div>
                <div class="concil-body">
                  <div class="concil-title">Agência Hive — PIX</div>
                  <div class="concil-desc">Conciliado automaticamente</div>
                </div>
                <div class="concil-val" style="color: var(--green-600);">R$12.000</div>
              </div>
              <div class="concil-item">
                <div class="concil-icon">✓</div>
                <div class="concil-body">
                  <div class="concil-title">Tráfego Forte — cartão</div>
                  <div class="concil-desc">Conciliado automaticamente</div>
                </div>
                <div class="concil-val" style="color: var(--green-600);">R$9.100</div>
              </div>
              <div class="concil-item">
                <div class="concil-icon mismatch">!</div>
                <div class="concil-body">
                  <div class="concil-title">GrowthLab — boleto</div>
                  <div class="concil-desc">Pagamento parcial detectado</div>
                </div>
                <div class="concil-val" style="color: var(--red-600);">R$3.000</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </main>
</div>

<script>
  function setActive(el) {
    document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
  }

  function toggleSwitch(el) {
    el.classList.toggle('off');
  }

  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.bar-fill.animate').forEach(bar => {
        bar.style.width = bar.dataset.width;
        bar.classList.remove('animate');
      });
    }, 300);
  });
</script>
</body>
</html>
